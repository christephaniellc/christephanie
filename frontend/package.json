{
  "name": "christephanie-pwa",
  "version": "2.3.0",
  "type": "module",
  "description": "Nuptials!",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "https-preview": "serve dist",
    "prettier:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "lint:check": "eslint --max-warnings=0 \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "ts:check": "tsc --noEmit",
    "test:unit": "jest --config jest.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:types": "swagger-typescript-api -p ../backend/src/swagger.json -o ./src/types -n api.ts"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.2.4",
    "@auth0/auth0-spa-js": "^2.1.3",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fontsource/orbitron": "^5.1.1",
    "@mui/icons-material": "^5.15.0",
    "@mui/joy": "^5.0.0-beta.51",
    "@mui/lab": "5.0.0-alpha.156",
    "@mui/material": "^5.15.0",
    "@mui/system": "^5.15.0",
    "@mui/utils": "^5.15.0",
    "@tanstack/react-query": "^5.62.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "is-mobile": "^4.0.0",
    "notistack": "^3.0.1",
    "polished": "^4.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.11",
    "react-helmet-async": "^2.0.3",
    "react-hook-form": "^7.54.2",
    "react-hotkeys-hook": "^4.4.1",
    "react-router-dom": "^6.21.0",
    "recoil": "^0.7.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.19.0",
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@playwright/test": "^1.40.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/svelte": "^5.2.6",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.19.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "^15.14.0",
    "https-localhost": "^4.7.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "3.1.1",
    "swagger-typescript-api": "^13.0.23",
    "ts-jest": "^29.2.5",
    "tslint": "^6.1.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^0.17.4"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx,json}": [
      "eslint --max-warnings=0"
    ]
  },
  "author": {
    "name": "Toph",
    "email": "dev@bungalowfortress.com",
    "url": "https://christephanie.com"
  }
}
