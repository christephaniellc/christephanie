## Run a basic python web server to host the coverage report
local_resource(
    'HTTP server',
    serve_cmd=python_name + ' -m http.server --bind 127.0.0.1 --directory .coveragereport 8000',
    allow_parallel=True,
    labels=['Tooling']
)

## Runs unit tests only (no system or integration tests)
local_resource(
    '.NET Unit Tests',
    cmd='pwsh -command .tilt/scripts/dotnet-test-coverage.ps1 .coveragereport/UnitTests UnitTests',
    auto_init=False, # Unit tests are faster, but still take time. Dev may instead run all tests manually.
    trigger_mode=TRIGGER_MODE_MANUAL,
    deps=['../.buildcomplete'],
    ignore=dotnet_ignore_list,
    resource_deps=['.Net Report Generator'],
    labels=["Tests", 'Manual'],
    links=[
        link('http://127.0.0.1:8000/UnitTests/', 'Coverage Report'),
        link('http://127.0.0.1:8000/UnitTests/results.xml', 'Test Results'),
    ]
)

## Runs all *Tests.csproj
local_resource(
    '.NET All Tests',
    cmd='pwsh -command .tilt/scripts/dotnet-test-coverage.ps1 .coveragereport/all Tests',
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
    resource_deps=['.Net Report Generator'],
    labels=["Tests", 'Manual'],
    links=[
        link('http://127.0.0.1:8000/all/', 'Coverage Report'),
        link('http://127.0.0.1:8000/all/results.xml', 'Test Results'),
    ]
)

