# Get Me A Token So I Can Call Things That Take A Token
########################################################
cmd_button(name='UPLoginAndGetServiceToken',
           text='Login and Get Token',
           icon_name='login',
           inputs=[
            text_input(name='USERNAME', default='cloudadmin', label='Username', placeholder=''),
            text_input(name='PASSWORD', default='', label='Password', placeholder=''),
            text_input(name='SERVICE', default='engine-pool', label='Service Name', placeholder='')
           ],
           location=location.NAV,
           # If you need env var expansion *within the command itself*
           # you'll need to run it via a shell.           
           argv=['pwsh', '-command', 'cd .tilt/scripts ; ./login-and-get-token.ps1 https://' + dev_tenant_name + '.secureplatform.io ' + ui_token_file + ' ' + shell_ui_token_file]
   )
