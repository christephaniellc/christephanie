## Make sure the report generator tool is installed
local_resource(
    '.Net Report Generator',
    cmd='pwsh -command .tilt/scripts/dotnet-reportgenerator.ps1',
    allow_parallel=True,
    #resource_deps=['Nuget'],
    labels=['Tooling']
