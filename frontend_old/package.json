{
  "name": "frontend-cra",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@auth0/auth0-react": "^2.2.4",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^6.1.9",
    "@mui/material": "^6.1.9",
    "@react-google-maps/api": "^2.20.3",
    "@tanstack/react-query": "^5.62.0",
    "@types/node": "^16.18.121",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "history": "^5.3.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "6",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md}'",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "generate:types": "openapi-typescript ./swagger.json --output ./src/types/api.ts",
    "generate:types:watch": "openapi-typescript ./swagger.json --output ./src/types/api.ts --watch",
    "generate:all": "npm run generate:types && npm run generate:client",
    "generate:client": "openapi-typescript-codegen --input ./swagger.json --output ./src/services/apiClient.ts --client axios --useOptions"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-syntax-flow": "^7.26.0",
    "@babel/plugin-transform-react-jsx": "^7.25.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.4.4",
    "openapi-typescript-codegen": "^0.29.0",
    "ts-jest": "^29.2.5"
  }
}
